# --- Provider selection ---
PROVIDER=groq

# Groq (default) — get a key at https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI (only if PROVIDER=openai) — https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# --- Optional overrides (defaults shown) ---
# MODEL=whisper-large-v3-turbo
# LANGUAGE=en
# INPUT_DEVICE=            # blank = system default; run tools/list_devices.py to find an index
# VAD_AGGRESSIVENESS=2     # 0 (lax) .. 3 (strict)
# SILENCE_HANGOVER_MS=600  # pause length that ends an utterance
# MAX_UTTERANCE_S=20       # force a new entry at least this often during long speech
# MIN_SPEECH_MS=250        # ignore blips shorter than this
# PREROLL_MS=300           # audio kept before speech onset (avoids clipped first word)
# LOG_DIR=transcripts
